# PostgreSQL connection string. The default matches `npm run db:up`
# (docker compose postgres exposed on host port 5434).
DATABASE_URL=postgres://spanish_cards:spanish_cards@localhost:5434/spanish_cards

# Port the API server listens on.
PORT=4100

# Single-user login credentials (plain text comparison, MVP).
APP_USERNAME=admin
APP_PASSWORD=change-me

# Secret used to sign session cookies. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string
