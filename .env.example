# PostgreSQL connection string. The default matches `npm run db:up`
# (docker compose postgres exposed on host port 5434).
DATABASE_URL=postgres://spanish_cards:spanish_cards@localhost:5434/spanish_cards

# Port the API server listens on.
PORT=4100

# Single-user login credentials (plain text comparison, MVP).
APP_USERNAME=admin
APP_PASSWORD=change-me

# Secret used to sign session cookies. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Bearer token for the MCP endpoint (/mcp). Use a long random string, e.g.
# `openssl rand -hex 32`. If unset, /mcp is disabled and returns a
# configuration error.
MCP_TOKEN=change-me-to-a-long-random-token

# OpenAI secret key for explanation generation. If unset, the explanation
# endpoint returns a 502 error (the server starts and runs normally without it).
OPENAI_SECRET_KEY=

# Override the OpenAI base URL (e.g. to point at a local stub during testing).
# Leave unset in production and development — only the e2e stack sets this.
OPENAI_BASE_URL=
