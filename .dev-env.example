# Compose-only settings. Copy to .dev-env and pass it with:
# docker compose --env-file .dev-env up -d postgres

# PostgreSQL container settings. The app container connects to postgres:5432
# internally; POSTGRES_HOST_PORT is only for host tools like psql, migrations,
# and the local dev server DATABASE_URL.
POSTGRES_USER=spanish_cards
POSTGRES_PASSWORD=spanish_cards
POSTGRES_DB=spanish_cards
POSTGRES_HOST_PORT=5434

# App container port mapping. APP_CONTAINER_PORT is the port Express listens on
# inside the container; APP_HOST_PORT is the host port exposed by Docker.
APP_CONTAINER_PORT=4100
APP_HOST_PORT=4100

# Runtime app environment file mounted into the app container. Keep secrets and
# app settings such as APP_USERNAME, APP_PASSWORD, SESSION_SECRET, and MCP_TOKEN
# in that file rather than this Compose env file.
APP_ENV_FILE=.env
