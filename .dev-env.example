# Compose-only settings for local development. Copy to .dev-env. The pnpm
# scripts pass this file automatically (npm run db:up / db:down); you never
# need --env-file by hand.

# Namespaces Docker containers, networks, and volumes for local development.
COMPOSE_PROJECT_NAME=spanish-cards-dev

# PostgreSQL container settings. Host port 5436 must match DATABASE_URL in
# .env (5434 belongs to the prod stack on this host).
POSTGRES_USER=spanish_cards
POSTGRES_PASSWORD=spanish_cards
POSTGRES_DB=spanish_cards
POSTGRES_HOST_PORT=5436

# Host port for the app container if the `app` profile is ever started from
# this env file for testing. Normal dev never starts it (the dev API is a
# local tsx process on 4102), but 4100 — the compose-file default — is the
# always-running prod container, so a non-conflicting port is set explicitly.
APP_HOST_PORT=4103
