# Compose-only settings for production. Copy to .prod-env on the production
# host and update values before running Docker Compose.

# Namespaces Docker containers, networks, and volumes for production.
COMPOSE_PROJECT_NAME=spanish-cards-prod

# PostgreSQL container settings. The app container connects to postgres:5432
# internally; POSTGRES_HOST_PORT is only for host access to Postgres.
POSTGRES_USER=spanish_cards
POSTGRES_PASSWORD=change-me
POSTGRES_DB=spanish_cards
POSTGRES_HOST_PORT=5432

# App container port mapping. APP_CONTAINER_PORT is the port Express listens on
# inside the container; APP_HOST_PORT is the host port exposed by Docker.
APP_CONTAINER_PORT=4100
APP_HOST_PORT=4100

# Runtime app environment file loaded into the app container.
APP_ENV_FILE=.prod.app.env
