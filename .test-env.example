# Compose-only settings for Playwright E2E. Copy to .test-env to override
# locally. E2E uses a separate Compose project and removes its volume after each
# run, so migrations are exercised against a fresh database from scratch.
COMPOSE_PROJECT_NAME=spanish-cards-e2e

POSTGRES_USER=spanish_cards
POSTGRES_PASSWORD=spanish_cards
POSTGRES_DB=spanish_cards_test
POSTGRES_HOST_PORT=55435

# Distinct from the dev ports (4101/4102) so a running dev stack is never
# reused or touched by the e2e suite.
API_PORT=4112
CLIENT_PORT=4113

# Host port for the app container if the `app` profile is ever started from
# this env file for testing. The e2e suite never starts it (it runs local node
# processes on the ports above), but 4100 — the compose-file default — is the
# always-running prod container, so a non-conflicting port is set explicitly.
APP_HOST_PORT=4114
